{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    //sql server connection string
    "SqlServer": "Server=localhost,1433;Database=NextDotNet;User ID=sa;Password=yourStrong(!)Password;MultipleActiveResultSets=True;TrustServerCertificate=True;",
    //postgresql connection string
    "Postgres": "Host=ep-old-fog-ao07xe3q.c-2.ap-southeast-1.aws.neon.tech;Port=5432;Database=neondb;Username=neondb_owner;Password=npg_ygAjvx9IY5cd;SSL Mode=Require;Trust Server Certificate=true"
  },
  "Serilog": {
    // Khai báo các package sink sẽ dùng — bắt buộc phải có nếu cấu hình qua appsettings.json
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.MSSqlServer",
      "Serilog.Expressions"
      // Cho phép dùng biểu thức string trong Filter
    ],

    // Mức log tối thiểu mặc định và override theo namespace
    "MinimumLevel": {
      "Default": "Information",   // Ghi tất cả log từ Information trở lên
      "Override": {
        "Microsoft": "Warning",   // Bỏ qua log Information/Debug của Microsoft
        "System": "Warning",      // Bỏ qua log Information/Debug của System
        "JobSchedule": "Information" // Giữ lại log Information của namespace JobSchedule
      }
    },

    "WriteTo": [

      // ─────────────────────────────────────────────
      // LOGGER 1: Ghi log THÔNG THƯỜNG vào bảng [Logs]
      // Điều kiện: KHÔNG có property JobName (tức là log nghiệp vụ bình thường)
      // ─────────────────────────────────────────────
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {

            // Loại trừ các log có JobName → chỉ ghi log không liên quan đến Job
            "Filter": [
              {
                "Name": "ByExcluding",
                "Args": {
                  "expression": "@Properties['JobName'] is not null"
                }
              }
            ],

            "WriteTo": [
              {
                // Async sink: ghi log bất đồng bộ, tránh block thread chính
                "Name": "Async",
                "Args": {
                  "configure": [
                    {
                      "Name": "MSSqlServer",
                      "Args": {
                        "connectionString": "Server=localhost,1433;Database=NextDotNet;User ID=sa;Password=yourStrong(!)Password;MultipleActiveResultSets=True;TrustServerCertificate=True;",
                        "tableName": "Logs",            // Bảng chứa log thông thường
                        "autoCreateSqlTable": true,     // Tự tạo bảng nếu chưa có
                        "restrictedToMinimumLevel": "Warning", // Chỉ ghi Warning trở lên vào DB
                        "batchPostingLimit": 50,        // Ghi tối đa 50 log mỗi lần batch
                        "period": "00:00:05",           // Flush vào DB mỗi 5 giây
                        "columnOptionsSection": {
                          // Bỏ 2 cột mặc định để giảm dung lượng DB
                          "removeStandardColumns": [ "MessageTemplate", "Properties" ]
                        }
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      },

      // ─────────────────────────────────────────────
      // LOGGER 2: Ghi log JOB vào bảng [JobLogs]
      // Điều kiện: CHỈ ghi khi có property JobName
      // ─────────────────────────────────────────────
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {

            // Chỉ giữ lại các log có JobName → tách riêng log của background job
            "Filter": [
              {
                "Name": "ByIncludingOnly",
                "Args": {
                  "expression": "@Properties['JobName'] is not null"
                }
              }
            ],

            "WriteTo": [
              {
                "Name": "Async",
                "Args": {
                  "configure": [
                    {
                      "Name": "MSSqlServer",
                      "Args": {
                        "connectionString": "Server=localhost,1433;Database=NextDotNet;User ID=sa;Password=yourStrong(!)Password;MultipleActiveResultSets=True;TrustServerCertificate=True;",
                        "tableName": "JobLogs",              // Bảng riêng cho Job log
                        "autoCreateSqlTable": true,
                        "restrictedToMinimumLevel": "Information", // Ghi cả Information (chi tiết hơn)
                        "batchPostingLimit": 50,
                        "period": "00:00:05",
                        "columnOptionsSection": {
                          "removeStandardColumns": [ "MessageTemplate", "Properties" ]
                        }
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      }
    ],

    // Enrich: gắn thêm thông tin vào mỗi log event
    "Enrich": [
      "FromLogContext",    // Lấy thêm property từ LogContext.PushProperty(...)
      "WithMachineName",  // Gắn tên máy chủ đang chạy (hữu ích khi deploy nhiều instance)
      "WithThreadId"      // Gắn Thread ID (hữu ích để debug async/concurrent)
    ],

    // Property mặc định gắn vào tất cả log
    "Properties": {
      "Application": "MyAppName",   // Tên ứng dụng
      "Environment": "Production"   // Môi trường đang chạy
    }
  },
  "AppSettings": {
